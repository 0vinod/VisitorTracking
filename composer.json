{
    "name": "0vinod/visitor-tracking",
    "description": "Visitor tracking package for Laravel applications",
    "keywords": [
        "laravel",
        "visitor",
        "tracking",
        "analytics"
    ],
    "type": "library",
    "license": "MIT",

    "authors": [
        {
            "name": "Vinod",
            "email": "vinod190596@gmail.com"
        }
    ],

    "require": {
        "php": "^8.0",
        "illuminate/support": "^9.0|^10.0|^11.0"
    },

    "autoload": {
        "psr-4": {
            "Vinod\\VisitorTracking\\": "src/"
        }
    },

    "autoload-dev": {
        "psr-4": {
            "Vinod\\VisitorTracking\\Tests\\": "tests/"
        }
    },

    "extra": {
        "laravel": {
            "providers": [
                "Vinod\\VisitorTracking\\VisitorTrackingServiceProvider"
            ]
        }
    },

    "minimum-stability": "stable",
    "prefer-stable": true
}